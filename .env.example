# PikPak authentication configuration
# Copy this file to .env and fill in your real information

# RefreshToken authentication
PIKPAK_REFRESH_TOKEN=your_refresh_token

# Proxy settings (optional)
# PIKPAK_PROXY=http://127.0.0.1:7890

# Other settings (optional)
# PIKPAK_DEVICE_ID=[device ID]
# PIKPAK_DEVICE_NAME=pikpak-downloader

# OAuth overrides (optional)
# 默认留空即可；仅在需要替换上游 pikpakcli 内置 OAuth 凭据时才设置。
# PIKPAK_CLIENT_ID=
# PIKPAK_CLIENT_SECRET=
